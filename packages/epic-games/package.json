{
  "name": "@rlsdk/epic-games",
  "version": "1.0.2",
  "description": "TypeScript SDK for RocketLeague (Epic Games) - Auto-generated type definitions",
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./types": {
      "bun": "./types/index.ts",
      "import": "./types/index.ts",
      "types": "./types/index.ts"
    },
    "./types/*": {
      "bun": "./types/*.ts",
      "import": "./types/*.ts",
      "types": "./types/*.ts"
    },
    "./structs": {
      "bun": "./structs/index.ts",
      "import": "./structs/index.ts",
      "types": "./structs/index.ts"
    },
    "./structs/*": {
      "bun": "./structs/*.ts",
      "import": "./structs/*.ts",
      "types": "./structs/*.ts"
    },
    "./classes": {
      "bun": "./classes/index.ts",
      "import": "./classes/index.ts",
      "types": "./classes/index.ts"
    },
    "./classes/*": {
      "bun": "./classes/*.ts",
      "import": "./classes/*.ts",
      "types": "./classes/*.ts"
    },
    "./enums": {
      "bun": "./enums/index.ts",
      "import": "./enums/index.ts",
      "types": "./enums/index.ts"
    },
    "./enums/*": {
      "bun": "./enums/*.ts",
      "import": "./enums/*.ts",
      "types": "./enums/*.ts"
    },
    "./offsets": {
      "bun": "./offsets/index.ts",
      "import": "./offsets/index.ts",
      "types": "./offsets/index.ts"
    },
    "./offsets/*": {
      "bun": "./offsets/*.ts",
      "import": "./offsets/*.ts",
      "types": "./offsets/*.ts"
    },
    "./parameters": {
      "bun": "./parameters/index.ts",
      "import": "./parameters/index.ts",
      "types": "./parameters/index.ts"
    },
    "./parameters/*": {
      "bun": "./parameters/*.ts",
      "import": "./parameters/*.ts",
      "types": "./parameters/*.ts"
    },
    "./constants": {
      "bun": "./constants/index.ts",
      "import": "./constants/index.ts",
      "types": "./constants/index.ts"
    },
    "./constants/*": {
      "bun": "./constants/*.ts",
      "import": "./constants/*.ts",
      "types": "./constants/*.ts"
    }
  },
  "files": [
    "classes",
    "constants",
    "enums",
    "offsets",
    "parameters",
    "structs",
    "types",
    "index.ts",
    "README.md"
  ],
  "keywords": [
    "rocket-league",
    "epic-games",
    "unreal-engine",
    "sdk",
    "types",
    "typescript",
    "bun"
  ],
  "author": "Stev Peifer <stev.p@outlook.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ObscuritySRL/rlsdk.git",
    "directory": "packages/epic-games"
  },
  "bugs": {
    "url": "https://github.com/ObscuritySRL/rlsdk/issues"
  },
  "homepage": "https://github.com/ObscuritySRL/rlsdk/tree/main/packages/epic-games#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "bun-memory": "^2",
    "typescript": "^5"
  }
}
